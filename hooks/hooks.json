          {
            "type": "command",
            "command": "node -e \"var p=require('path'),f=require('fs'),b='scripts/hooks/plugin-hook-bootstrap.cjs',d=p.join(require('os').homedir(),'.claude'),r='',t=[p.join(d,'plugins/marketplaces/crs/plugins/crs')];try{var c=p.join(d,'plugins/cache/crs/crs');if(f.existsSync(c))f.readdirSync(c).forEach(function(v){var vp=p.join(c,v);if(!r&&f.statSync(vp).isDirectory()&&f.existsSync(p.join(vp,b)))r=vp})}catch(e){}if(!r)for(var i=0;i<t.length;i++){if(f.existsSync(p.join(t[i],b))){r=t[i];break}}if(!r)r=p.resolve('.');process.env.CLAUDE_PLUGIN_ROOT=r;require(p.join(r,b))\" scripts/conversation-logger/hooks/session-start.js",
            "timeout": 5
          }
        ],
        "description": "初始化对话记录器",
        "id": "conv:session:start"
      }
